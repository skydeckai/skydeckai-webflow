---
import { legacyEntries } from "../lib/legacy";
import { localeUrl, type Locale } from "../i18n/locales";

/**
 * Generated post-card list for blog index / category pages whose source
 * export had no card list (several locale trees). Lists the locale's own
 * posts (fallback-aware via legacyEntries), newest first.
 */
interface Props {
  locale: Locale;
  atRoot?: boolean;
}
const { locale, atRoot = false } = Astro.props;

const posts = legacyEntries(locale)
  .filter((e) => e.path.startsWith("blog/"))
  .sort((a, b) => (a.date ?? "").localeCompare(b.date ?? ""))
  .reverse();
const href = (p: string) => (atRoot ? `/${p}` : localeUrl(locale, p));
---

<div class="bloglist">
  {posts.map((p) => (
    <a href={href(p.path)} class="postcard">
      {p.ogImage && <img src={p.ogImage} alt="" loading="lazy" />}
      <span class="meta">
        <span class="title">{p.h1}</span>
        {p.lede && <span class="lede">{p.lede}</span>}
        {p.date && <span class="date">{p.date}</span>}
      </span>
    </a>
  ))}
</div>

<style>
  .bloglist {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 18px;
    margin-top: 8px;
  }
  .postcard {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--color-warmwhite);
    border: 1px solid var(--hairline);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--card-shadow);
  }
  .postcard img {
    width: 100%;
    aspect-ratio: 1.9;
    object-fit: cover;
    display: block;
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 18px 18px;
  }
  .title {
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    color: var(--color-deepink);
  }
  .lede {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-inksoft);
  }
  .date {
    font-size: 12.5px;
    color: var(--color-faint);
  }
</style>
