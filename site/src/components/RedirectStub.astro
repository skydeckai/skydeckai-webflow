---
/**
 * Permanent-move stub for retired leftover-template URLs (SEO map §3).
 * GitHub Pages cannot emit server 301s; a zero-delay meta refresh plus a
 * canonical pointing at the destination is the strongest static equivalent.
 */
interface Props {
  target: string;
}
const { target } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={new URL(target, "https://www.skydeck.ai").href} />
    <title>Moved</title>
  </head>
  <body style="font-family:Georgia,serif;padding:40px">
    <p>This page has moved: <a href={target}>{target}</a></p>
  </body>
</html>
