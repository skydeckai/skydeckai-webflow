---
// Static port of budgetMock from the design doc.
// Pure HTML + inline styles mirroring the source React.createElement builder.
---

<div
  class="app"
  style="border-radius:13px;overflow:hidden;border:1px solid rgba(42,51,107,.2);box-shadow:0 22px 50px rgba(30,36,71,.2);background:#10132E;padding:20px;text-align:left"
>
  <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px">
    <span style="font-size:12.5px;color:rgba(233,234,246,.55)">Monthly budget</span>
    <span style="font-size:13px;font-weight:700;color:#E9EAF6">$2,140 <span style="color:rgba(233,234,246,.55);font-weight:500">/ $3,000</span></span>
  </div>
  <div style="height:11px;border-radius:100px;background:rgba(255,255,255,.08);overflow:hidden;margin-bottom:8px">
    <div style="width:71%;height:100%;border-radius:100px;background:linear-gradient(90deg,#4351B4,#8590E8)"></div>
  </div>
  <div style="display:flex;justify-content:space-between;font-size:11.5px;color:rgba(233,234,246,.55);margin-bottom:16px">
    <span>71% used · warn at 80%</span>
    <span style="color:#D2A85C">overage: warn</span>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:11px">
    <div style="padding:12px 13px;border-radius:10px;background:rgba(255,255,255,.04)">
      <div style="font-size:20px;font-weight:700;color:#E9EAF6">6</div>
      <div style="font-size:11px;color:rgba(233,234,246,.55);margin-top:1px">pods running</div>
    </div>
    <div style="padding:12px 13px;border-radius:10px;background:rgba(255,255,255,.04)">
      <div style="font-size:20px;font-weight:700;color:#E9EAF6">8 max</div>
      <div style="font-size:11px;color:rgba(233,234,246,.55);margin-top:1px">concurrent limit</div>
    </div>
  </div>
</div>
