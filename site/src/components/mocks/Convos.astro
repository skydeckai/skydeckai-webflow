---
// Static port of convosMock from the design doc.
// Pure HTML + inline styles mirroring the source React.createElement builder.
---

<div
  class="app"
  style="border-radius:13px;overflow:hidden;border:1px solid rgba(42,51,107,.2);box-shadow:0 22px 50px rgba(30,36,71,.2);background:#10132E;padding:12px 10px;text-align:left"
>
  <div style="display:flex;gap:4px;margin-bottom:6px">
    <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;padding:7px 9px;border-radius:7px;background:rgba(133,144,232,.16);color:#E9EAF6">✉ Conversations</div>
    <div style="display:flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;padding:7px 9px;border-radius:7px;color:rgba(233,234,246,.55)">▤ Pods <span style="font-size:10px;padding:0 5px;border-radius:6px;background:rgba(255,255,255,.1)">4</span></div>
  </div>
  <div style="display:flex;align-items:center;gap:7px;padding:8px 9px;border-radius:8px;background:rgba(255,255,255,.04);font-size:11.5px;color:rgba(233,234,246,.55);margin-bottom:2px">⌕ Search conversations…</div>

  <div style="padding:11px 10px 5px;font-size:10.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(233,234,246,.55)">Starred  1</div>
  <div style="display:flex;align-items:flex-start;gap:9px;padding:10px;border-radius:9px;background:rgba(133,144,232,.08)">
    <span style="flex:none;width:22px;height:22px;border-radius:6px;background:rgba(133,144,232,.16);color:#8590E8;display:flex;align-items:center;justify-content:center;font-size:11px">✉</span>
    <div style="flex:1;min-width:0">
      <div style="display:flex;align-items:center;gap:6px">
        <span style="color:#D2A85C;font-size:11px">★</span>
        <span style="font-size:12.5px;font-weight:600;color:#E9EAF6">Q3 launch messaging</span>
      </div>
      <div style="font-size:10.5px;color:rgba(233,234,246,.55);margin-top:2px">Updated 2 min ago · 4,120 characters</div>
    </div>
    <span style="color:rgba(233,234,246,.55);font-size:11px">☆</span>
  </div>

  <div style="padding:11px 10px 5px;font-size:10.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(233,234,246,.55)">Recent  3</div>
  <div style="display:flex;align-items:flex-start;gap:9px;padding:10px;border-radius:9px;background:transparent">
    <span style="flex:none;width:22px;height:22px;border-radius:6px;background:rgba(133,144,232,.16);color:#8590E8;display:flex;align-items:center;justify-content:center;font-size:11px">✉</span>
    <div style="flex:1;min-width:0">
      <div style="display:flex;align-items:center;gap:6px">
        <span style="font-size:12.5px;font-weight:600;color:#E9EAF6">Competitor teardown</span>
      </div>
      <div style="font-size:10.5px;color:rgba(233,234,246,.55);margin-top:2px">Updated 1 h ago · 8,940 characters</div>
    </div>
    <span style="font-size:10px;font-weight:700;min-width:17px;height:17px;padding:0 4px;border-radius:100px;background:#4351B4;color:#fff;display:flex;align-items:center;justify-content:center">3</span>
  </div>
  <div style="display:flex;align-items:flex-start;gap:9px;padding:10px;border-radius:9px;background:transparent">
    <span style="flex:none;width:22px;height:22px;border-radius:6px;background:rgba(133,144,232,.16);color:#8590E8;display:flex;align-items:center;justify-content:center;font-size:11px">✉</span>
    <div style="flex:1;min-width:0">
      <div style="display:flex;align-items:center;gap:6px">
        <span style="font-size:12.5px;font-weight:600;color:#E9EAF6">Onboarding email rewrite</span>
      </div>
      <div style="font-size:10.5px;color:rgba(233,234,246,.55);margin-top:2px">Updated yesterday · 2,050 characters</div>
    </div>
    <span style="color:rgba(233,234,246,.55);font-size:11px">☆</span>
  </div>
  <div style="display:flex;align-items:flex-start;gap:9px;padding:10px;border-radius:9px;background:transparent">
    <span style="flex:none;width:22px;height:22px;border-radius:6px;background:rgba(133,144,232,.16);color:#8590E8;display:flex;align-items:center;justify-content:center;font-size:11px">✉</span>
    <div style="flex:1;min-width:0">
      <div style="display:flex;align-items:center;gap:6px">
        <span style="font-size:12.5px;font-weight:600;color:#E9EAF6">RFP — security questionnaire</span>
      </div>
      <div style="font-size:10.5px;color:rgba(233,234,246,.55);margin-top:2px">Updated 2 d ago · 15,300 characters</div>
    </div>
    <span style="color:rgba(233,234,246,.55);font-size:11px">☆</span>
  </div>
</div>
