---
// Static port of workspaceMock (+ _podRail, _multiPanes) from the design doc.
// Pure HTML + inline styles mirroring the source React.createElement builders.
---

<div
  class="app"
  style="border-radius:14px;overflow:hidden;border:1px solid rgba(42,51,107,.22);box-shadow:0 40px 90px rgba(30,36,71,.28);background:#0F1330;text-align:left"
>
  <!-- top bar -->
  <div
    style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:#141834;border-bottom:1px solid rgba(255,255,255,.08)"
  >
    <div style="display:flex;align-items:center;gap:8px">
      <img src="/assets/logo-mark.png" alt="SkyDeck.ai" style="height:20px" />
      <span style="font-size:13px;font-weight:700;color:#F1F1FA">SkyDeck.ai</span>
      <span style="color:rgba(233,234,246,.3)">/</span>
      <span
        style="display:inline-flex;align-items:center;gap:6px;font-size:12px;color:rgba(233,234,246,.7);padding:3px 9px;border-radius:100px;background:rgba(255,255,255,.05)"
      >
        <span style="width:12px;height:12px;border-radius:4px;background:#3A4FA0"></span>
        East Agile
      </span>
    </div>
    <div style="flex:1;display:flex;justify-content:center">
      <div
        style="display:flex;align-items:center;gap:8px;font-size:12px;color:rgba(233,234,246,.5);padding:6px 12px;border-radius:8px;background:rgba(255,255,255,.04);min-width:280px"
      >
        <span>⌕</span>
        <span style="flex:1">Search pods, conversations…</span>
        <span class="mono" style="font-size:10px;padding:1px 5px;border-radius:4px;background:rgba(255,255,255,.08)">⌘K</span>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:12px">
      <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;color:rgba(233,234,246,.7)">
        <span>⚙</span>
        Control Center
      </span>
      <span style="color:rgba(233,234,246,.6)">☾</span>
      <span
        style="width:24px;height:24px;border-radius:50%;background:#3A4FA0;color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center"
      >LS</span>
    </div>
  </div>

  <!-- body -->
  <div style="display:flex;height:486px">
    <!-- _podRail -->
    <aside
      style="width:236px;flex:none;background:#10132E;border-right:1px solid rgba(255,255,255,.09);padding:12px 10px;display:flex;flex-direction:column;gap:4px"
    >
      <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:4px">
        <div
          style="display:flex;align-items:center;gap:6px;justify-content:center;font-size:11.5px;font-weight:600;padding:8px;border-radius:8px;background:transparent;color:#E9EAF6;border:1px solid rgba(255,255,255,.09)"
        >
          <span>+</span>New Conversation
        </div>
        <div
          style="display:flex;align-items:center;gap:6px;justify-content:center;font-size:11.5px;font-weight:600;padding:8px;border-radius:8px;background:#4351B4;color:#fff;border:none"
        >
          <span>+</span>Agentic Pod
        </div>
      </div>
      <div style="display:flex;gap:4px;margin-bottom:2px">
        <div
          style="display:flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;padding:7px 9px;border-radius:7px;background:transparent;color:rgba(233,234,246,.55)"
        >Conversations</div>
        <div
          style="display:flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;padding:7px 9px;border-radius:7px;background:rgba(133,144,232,.16);color:#E9EAF6"
        >
          Pods
          <span style="font-size:10px;padding:0 5px;border-radius:6px;background:rgba(255,255,255,.1);color:rgba(233,234,246,.55)">4</span>
        </div>
      </div>
      <div
        style="display:flex;align-items:center;gap:7px;padding:8px 9px;border-radius:8px;background:rgba(255,255,255,.04);font-size:11.5px;color:rgba(233,234,246,.55);margin:2px 0 2px"
      >
        <span>⌕</span>Search pods…
      </div>

      <div
        style="display:flex;align-items:center;gap:6px;padding:12px 8px 5px;font-size:10.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(233,234,246,.55)"
      >
        Running
        <span style="color:rgba(233,234,246,.4)">2</span>
      </div>

      <div style="display:flex;align-items:center;gap:9px;padding:8px;border-radius:8px">
        <span
          class="mono"
          style="flex:none;width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,#3A4FA0,#6472C8);color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600"
        >CC</span>
        <span
          style="flex:1;min-width:0;font-size:12.5px;font-weight:500;color:#E9EAF6;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
        >billing-agent</span>
        <span style="width:6px;height:6px;border-radius:50%;background:#5BC08D;box-shadow:0 0 6px #5BC08D;display:inline-block"></span>
        <span style="color:rgba(233,234,246,.55);font-size:12px">☆</span>
      </div>
      <div style="display:flex;align-items:center;gap:9px;padding:8px;border-radius:8px">
        <span
          class="mono"
          style="flex:none;width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,#54608F,#8590E8);color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600"
        >OC</span>
        <span
          style="flex:1;min-width:0;font-size:12.5px;font-weight:500;color:#E9EAF6;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
        >nightly-crawler</span>
        <span style="width:6px;height:6px;border-radius:50%;background:#5BC08D;box-shadow:0 0 6px #5BC08D;display:inline-block"></span>
        <span style="color:rgba(233,234,246,.55);font-size:12px">☆</span>
      </div>

      <div
        style="display:flex;align-items:center;gap:6px;padding:12px 8px 5px;font-size:10.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:rgba(233,234,246,.55)"
      >
        Sleeping &amp; stopped
        <span style="color:rgba(233,234,246,.4)">2</span>
      </div>

      <div style="display:flex;align-items:center;gap:9px;padding:8px;border-radius:8px">
        <span
          class="mono"
          style="flex:none;width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,#C79A44,#E0C07E);color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600"
        >SP</span>
        <span
          style="flex:1;min-width:0;font-size:12.5px;font-weight:500;color:#E9EAF6;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
        >support-triage</span>
        <span style="width:6px;height:6px;border-radius:50%;background:#D2A85C;box-shadow:none;display:inline-block"></span>
        <span style="color:rgba(233,234,246,.55);font-size:12px">☆</span>
      </div>
      <div style="display:flex;align-items:center;gap:9px;padding:8px;border-radius:8px">
        <span
          class="mono"
          style="flex:none;width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,#54608F,#7D88B8);color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:600"
        >AC</span>
        <span
          style="flex:1;min-width:0;font-size:12.5px;font-weight:500;color:#E9EAF6;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
        >analytics-custom</span>
        <span style="width:6px;height:6px;border-radius:50%;background:#6B6F8F;box-shadow:none;display:inline-block"></span>
        <span style="color:rgba(233,234,246,.55);font-size:12px">☆</span>
      </div>

      <div
        style="margin-top:auto;display:flex;align-items:center;gap:9px;padding:9px 6px;border-top:1px solid rgba(255,255,255,.09)"
      >
        <span
          style="width:26px;height:26px;border-radius:50%;background:#3A4FA0;color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center"
        >LS</span>
        <span style="display:flex;flex-direction:column;line-height:1.25">
          <span style="font-size:12px;font-weight:600;color:#E9EAF6">Lawrence S.</span>
          <span style="font-size:11px;color:rgba(233,234,246,.55)">East Agile</span>
        </span>
      </div>
    </aside>

    <!-- _multiPanes -->
    <div
      style="flex:1;min-width:0;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:8px;padding:10px;background:#0A0D22"
    >
      <!-- p1: billing-agent (active) -->
      <div
        style="display:flex;flex-direction:column;min-width:0;min-height:0;background:#0F1330;border:1px solid rgba(133,144,232,.55);border-radius:8px;overflow:hidden"
      >
        <div style="display:flex;align-items:center;gap:7px;padding:6px 9px;background:#171B3C;border-bottom:1px solid rgba(255,255,255,.09)">
          <span style="color:#8590E8;font-size:11px">›</span>
          <span style="flex:none;width:6px;height:6px;border-radius:50%;background:#5BC08D;box-shadow:0 0 6px #5BC08D;display:inline-block"></span>
          <span style="font-size:11px;font-weight:600;color:#E9EAF6;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">billing-agent</span>
          <span class="mono" style="font-size:9px;padding:2px 6px;border-radius:5px;background:rgba(133,144,232,.16);color:#B7BEEA">claude-code</span>
          <div style="margin-left:auto;display:flex;align-items:center;gap:6px">
            <div style="display:flex;align-items:center;padding-left:5px">
              <span style="width:18px;height:18px;border-radius:50%;background:#3A4FA0;color:#fff;font-size:7.5px;font-weight:800;display:flex;align-items:center;justify-content:center;border:2px solid #171B3C;margin-left:-5px">YOU</span>
              <span style="width:18px;height:18px;border-radius:50%;background:#37406B;color:#cdd2ee;font-size:7.5px;font-weight:800;display:flex;align-items:center;justify-content:center;border:2px solid #171B3C;margin-left:-5px">JD</span>
              <span style="width:18px;height:18px;border-radius:50%;background:#37406B;color:#cdd2ee;font-size:7.5px;font-weight:800;display:flex;align-items:center;justify-content:center;border:2px solid #171B3C;margin-left:-5px">MP</span>
            </div>
            <span style="font-size:9px;color:rgba(233,234,246,.55)">you drive</span>
          </div>
        </div>
        <div class="mono" style="flex:1;min-height:0;padding:10px 11px;font-size:10px;line-height:1.7;color:#E5E8F4;overflow:hidden">
          <div><span style="color:#8FA0E0">claude</span><span style="color:rgba(233,234,246,.55)">›</span> reconciling June invoices…</div>
          <div><span style="color:#6FD3A6">✓ 3 mismatches resolved</span></div>
          <div><span style="color:rgba(233,234,246,.55)"># MP: check the partial-refund path</span></div>
          <div><span style="color:#8FA0E0">claude</span><span style="color:rgba(233,234,246,.55)">›</span> patching refunds.ts<span style="display:inline-block;width:6px;height:12px;background:#8590E8;margin-left:2px;vertical-align:-2px;animation:blink 1s step-end infinite"></span></div>
        </div>
      </div>

      <!-- p2: checkout-refactor -->
      <div
        style="display:flex;flex-direction:column;min-width:0;min-height:0;background:#0F1330;border:1px solid rgba(255,255,255,.09);border-radius:8px;overflow:hidden"
      >
        <div style="display:flex;align-items:center;gap:7px;padding:6px 9px;background:#171B3C;border-bottom:1px solid rgba(255,255,255,.09)">
          <span style="color:#8590E8;font-size:11px">›</span>
          <span style="flex:none;width:6px;height:6px;border-radius:50%;background:#5BC08D;box-shadow:0 0 6px #5BC08D;display:inline-block"></span>
          <span style="font-size:11px;font-weight:600;color:#E9EAF6;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">checkout-refactor</span>
          <span class="mono" style="font-size:9px;padding:2px 6px;border-radius:5px;background:rgba(133,144,232,.16);color:#B7BEEA">claude-code</span>
        </div>
        <div class="mono" style="flex:1;min-height:0;padding:10px 11px;font-size:10px;line-height:1.7;color:#E5E8F4;overflow:hidden">
          <div><span style="color:#8FA0E0">claude</span><span style="color:rgba(233,234,246,.55)">›</span> running test suite</div>
          <div><span style="color:#6FD3A6">✓ 128 passing</span><span style="color:rgba(233,234,246,.55)"> · 0 failing</span></div>
          <div><span style="color:#8FA0E0">claude</span><span style="color:rgba(233,234,246,.55)">›</span> commit "extract cart" <span style="display:inline-block;width:6px;height:12px;background:#8590E8;margin-left:2px;vertical-align:-2px;animation:blink 1s step-end infinite"></span></div>
        </div>
      </div>

      <!-- p3: nightly-crawler (openclaw) -->
      <div
        style="display:flex;flex-direction:column;min-width:0;min-height:0;background:#0F1330;border:1px solid rgba(255,255,255,.09);border-radius:8px;overflow:hidden"
      >
        <div style="display:flex;align-items:center;gap:7px;padding:6px 9px;background:#171B3C;border-bottom:1px solid rgba(255,255,255,.09)">
          <span style="color:#8590E8;font-size:11px">›</span>
          <span style="flex:none;width:6px;height:6px;border-radius:50%;background:#D2A85C;box-shadow:0 0 6px #D2A85C;display:inline-block"></span>
          <span style="font-size:11px;font-weight:600;color:#E9EAF6;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">nightly-crawler</span>
          <span class="mono" style="font-size:9px;padding:2px 6px;border-radius:5px;background:rgba(133,144,232,.16);color:#B7BEEA">openclaw</span>
        </div>
        <div class="mono" style="flex:1;min-height:0;padding:10px 11px;font-size:10px;line-height:1.7;color:#E5E8F4;overflow:hidden">
          <div><span style="color:rgba(233,234,246,.55)">[openclaw] gateway :7070 · detached</span></div>
          <div>crawled <span style="color:#B7BEEA">412</span> pages · queued 38</div>
          <div><span style="color:#D2A85C">◐ working around the clock</span><span style="display:inline-block;width:6px;height:12px;background:#8590E8;margin-left:2px;vertical-align:-2px;animation:blink 1s step-end infinite"></span></div>
        </div>
      </div>

      <!-- browser pane -->
      <div
        style="display:flex;flex-direction:column;min-width:0;min-height:0;border:1px solid rgba(255,255,255,.09);border-radius:8px;overflow:hidden;background:#fff"
      >
        <div style="display:flex;align-items:center;gap:8px;padding:6px 9px;background:#171B3C;border-bottom:1px solid rgba(255,255,255,.09)">
          <span style="color:rgba(233,234,246,.55);font-size:11px">↻</span>
          <span class="mono" style="display:flex;align-items:center;gap:6px;flex:1;font-size:9.5px;color:rgba(233,234,246,.55);padding:3px 8px;border-radius:5px;background:rgba(255,255,255,.05)">
            <span>🔒</span>localhost<span style="color:#B7BEEA">:3000</span>
          </span>
          <span style="font-size:9px;color:#8590E8">live preview</span>
        </div>
        <div style="flex:1;min-height:0;background:#F7F5EF;padding:11px;overflow:hidden">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:9px">
            <span style="font-size:11px;font-weight:800;color:#1E2447">Billing</span>
            <span style="width:28px;height:9px;border-radius:100px;background:#2A336B"></span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:8px">
            <div style="background:#fff;border-radius:7px;padding:8px;border:1px solid rgba(42,51,107,.12)">
              <div style="font-size:13px;font-weight:800;color:#1E2447">$48.2k</div>
              <div style="font-size:8px;color:#8A8FA6">collected</div>
            </div>
            <div style="background:#fff;border-radius:7px;padding:8px;border:1px solid rgba(42,51,107,.12)">
              <div style="font-size:13px;font-weight:800;color:#2F8F5F">99.1%</div>
              <div style="font-size:8px;color:#8A8FA6">reconciled</div>
            </div>
          </div>
          <div style="height:44px;border-radius:7px;background:linear-gradient(180deg,rgba(58,79,160,.16),rgba(58,79,160,.02));border:1px solid rgba(42,51,107,.1)"></div>
        </div>
      </div>
    </div>
  </div>
</div>
