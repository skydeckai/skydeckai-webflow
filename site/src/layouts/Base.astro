---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import { LANG_TAG, RTL, SITE, alternates, localeUrl, type Locale } from "../i18n/locales";
import { POSTHOG } from "../config/analytics";

interface Props {
  locale: Locale;
  /** locale-relative path with trailing slash, "" for the locale home */
  path: string;
  title: string;
  description: string;
  ogImage?: string;
  /** true when rendering the root (unprefixed) English copy of this page */
  atRoot?: boolean;
  /** hide chrome (nav/footer) — used by redirect stubs */
  bare?: boolean;
}

const { locale, path, title, description, ogImage, atRoot = false, bare = false } = Astro.props;

const canonicalPath = atRoot ? `/${path}` : localeUrl(locale, path);
const canonical = `${SITE}${canonicalPath}`;
const og = ogImage ?? "/assets/og-default.png";
const dir = RTL.includes(locale) ? "rtl" : "ltr";

const strings = import.meta.glob<Record<string, string>>("../i18n/strings/*.json", {
  eager: true,
  import: "default",
});
const en = strings["../i18n/strings/en.json"];
const t = { ...en, ...(strings[`../i18n/strings/${locale}.json`] ?? {}) };

/**
 * Content-Security-Policy via <meta> (GitHub Pages cannot set response headers).
 * Scripts are Astro-bundled external files, so no unsafe-inline for script-src.
 * style-src keeps 'unsafe-inline' for the design's style attributes. meta-CSP
 * cannot express frame-ancestors/report-uri — that needs a fronting CDN.
 */
const organizationLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "SkyDeck AI",
  url: SITE,
  logo: `${SITE}/assets/logo-mark.png`,
  sameAs: [
    "https://github.com/skydeckai",
    "https://x.com/SkyDeckAI",
    "https://www.linkedin.com/company/skydeck-ai",
    "https://www.youtube.com/@SkyDeckAI",
  ],
});

const csp = [
  "default-src 'self'",
  `script-src 'self' https://www.googletagmanager.com ${POSTHOG.assetsHost}`,
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: https://www.googletagmanager.com https://*.google-analytics.com",
  "font-src 'self'",
  `connect-src 'self' https://*.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://*.googletagmanager.com https://admin.skydeck.ai ${POSTHOG.apiHost} ${POSTHOG.assetsHost}`,
  "frame-src https://www.googletagmanager.com",
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self' https://www.google.com https://admin.skydeck.ai mailto:",
].join("; ");
---

<!doctype html>
<html lang={LANG_TAG[locale]} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content={csp} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates(path).map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SkyDeck.ai" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(og, SITE).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(og, SITE).href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={organizationLd} />
    <slot name="head" />
  </head>
  <body>
    {!bare && <Nav locale={locale} t={t} />}
    <slot />
    {!bare && <Footer locale={locale} path={path} t={t} />}
    {!bare && <ConsentBanner locale={locale} />}
    <script>
      import "../scripts/analytics.ts";
      import "../scripts/motion.ts";
    </script>
  </body>
</html>
