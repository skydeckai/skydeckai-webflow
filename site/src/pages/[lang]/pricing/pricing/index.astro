---
/**
 * Legacy SEO-map URL /{lang}/pricing/pricing/ — retired in favour of the single
 * canonical /{lang}/pricing/. Permanent-move stub (GitHub Pages can't emit a 301).
 */
import RedirectStub from "../../../../components/RedirectStub.astro";
import { LOCALES, localeUrl, type Locale } from "../../../../i18n/locales";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<RedirectStub target={localeUrl(locale, "pricing/")} />
