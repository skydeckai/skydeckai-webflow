---
import SimplePage from "../../layouts/SimplePage.astro";
import { legacyEntry } from "../../lib/legacy";

const entry = legacyEntry("en", "pricing/pricing/")!;
---

<SimplePage
  locale="en"
  path="pricing/"
  title={entry.title}
  description={entry.description}
  h1={entry.h1}
  eyebrow={entry.eyebrow}
  lede={entry.lede}
  ogImage={entry.ogImage}
  html={entry.html}
  atRoot
/>
